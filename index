<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>2026 Business Summit – Start Smart, Scale Fast</title>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800;900&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --navy: #093F6E;
    --pink: #FE0877;
    --cyan: #00bcd4;
    --white: #ffffff;
    --light-gray: #f5f5f5;
    --text-dark: #222222;
    --text-mid: #444444;
  }

  body {
    font-family: 'Open Sans', sans-serif;
    color: var(--text-dark);
    background: #fff;
  }

  /* NAV */
  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 40px;
    background: #000;
    border-bottom: 1px solid #222;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .nav-logo {
    font-family: 'Montserrat', sans-serif;
    font-weight: 800;
    font-size: 18px;
    color: var(--navy);
    letter-spacing: 1px;
  }
  .nav-logo span { color: var(--pink); }
  .btn-register {
    background: var(--pink);
    color: #fff;
    border: none;
    padding: 10px 22px;
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: 13px;
    border-radius: 4px;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    transition: background 0.2s;
  }
  .btn-register:hover { background: #c4157a; }

  /* HERO */
  .hero {
    background: linear-gradient(135deg, #e07a2f 0%, #c85d1e 40%, #1a2d4f 100%);
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 420px;
    position: relative;
    overflow: hidden;
  }
  .hero-left {
    padding: 60px 50px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    z-index: 2;
  }
  .hero-theme {
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    color: rgba(255,255,255,0.85);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 12px;
  }
  .hero h1 {
    font-family: 'Montserrat', sans-serif;
    font-weight: 900;
    font-size: 56px;
    line-height: 1.05;
    color: #fff;
    margin-bottom: 20px;
  }
  .hero-meta {
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    color: rgba(255,255,255,0.85);
    line-height: 1.8;
    letter-spacing: 0.5px;
    margin-bottom: 30px;
  }
  .hero-right {
    position: relative;
    overflow: hidden;
  }
  .hero-right img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }
  /* social icons in hero */
  .hero-socials {
    position: absolute;
    bottom: 20px;
    right: 20px;
    display: flex;
    gap: 10px;
    z-index: 3;
  }
  .hero-socials a {
    width: 32px;
    height: 32px;
    background: rgba(255,255,255,0.2);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 13px;
    text-decoration: none;
    transition: background 0.2s;
  }
  .hero-socials a:hover { background: rgba(255,255,255,0.4); }

  /* INFO SECTION */
  .info-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    padding: 60px 80px;
    gap: 60px;
    align-items: center;
    background: #fff;
  }
  .info-left h2 {
    font-family: 'Montserrat', sans-serif;
    font-weight: 900;
    font-size: 38px;
    line-height: 1.1;
    color: var(--navy);
    margin-bottom: 20px;
  }
  .info-left .date-line {
    font-family: 'Montserrat', sans-serif;
    font-weight: 600;
    font-size: 13px;
    color: var(--text-mid);
    line-height: 2;
  }
  .view-location {
    color: var(--navy);
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: 13px;
    text-decoration: underline;
    display: inline-block;
    margin-top: 8px;
    cursor: pointer;
  }
  .info-right p {
    font-size: 15px;
    line-height: 1.75;
    color: var(--text-mid);
    margin-bottom: 18px;
  }
  .info-right .early-bird {
    font-weight: 700;
    color: var(--text-dark);
  }

  /* COUNTDOWN */
  .countdown-section {
    background: #fff;
    padding: 40px 80px 60px;
    text-align: center;
  }
  .countdown {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0;
  }
  .countdown-item {
    text-align: center;
    padding: 0 30px;
  }
  .countdown-num {
    font-family: 'Montserrat', sans-serif;
    font-weight: 900;
    font-size: 72px;
    color: var(--text-dark);
    line-height: 1;
    display: block;
  }
  .countdown-label {
    font-family: 'Montserrat', sans-serif;
    font-size: 12px;
    color: var(--pink);
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-top: 6px;
  }
  .countdown-sep {
    font-family: 'Montserrat', sans-serif;
    font-weight: 900;
    font-size: 72px;
    color: var(--text-dark);
    line-height: 1;
    padding-bottom: 20px;
  }

  /* WHAT TO EXPECT */
  .expect-section {
    background: var(--navy);
    padding: 70px 80px;
    color: #fff;
    text-align: center;
  }
  .expect-section h2 {
    font-family: 'Montserrat', sans-serif;
    font-weight: 900;
    font-size: 32px;
    margin-bottom: 50px;
    color: #fff;
  }
  .expect-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
    margin-bottom: 50px;
  }
  .expect-item h3 {
    font-family: 'Montserrat', sans-serif;
    font-weight: 800;
    font-size: 16px;
    margin-bottom: 12px;
    color: #fff;
  }
  .expect-item p {
    font-size: 14px;
    line-height: 1.7;
    color: rgba(255,255,255,0.8);
  }
  .expect-images {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-top: 40px;
  }
  .expect-images .img-placeholder {
    height: 160px;
    border-radius: 8px;
    overflow: hidden;
    background: rgba(255,255,255,0.1);
  }
  .expect-images img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.85;
  }

  /* KEYNOTE SPEAKERS */
  .keynote-section {
    background: #fff;
    padding: 70px 80px;
    text-align: center;
  }
  .keynote-section h2 {
    font-family: 'Montserrat', sans-serif;
    font-weight: 900;
    font-size: 36px;
    color: var(--text-dark);
    margin-bottom: 50px;
  }
  .keynote-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    max-width: 900px;
    margin: 0 auto;
  }
  .keynote-card {
    border-radius: 20px;
    padding: 50px 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 240px;
  }
  .keynote-card.cyan-card { background: var(--cyan); }
  .keynote-card.pink-card { background: var(--pink); }
  .keynote-card h3 {
    font-family: 'Montserrat', sans-serif;
    font-weight: 900;
    font-size: 24px;
    line-height: 1.2;
    margin-bottom: 16px;
    color: #000;
  }
  .keynote-card.pink-card h3 { color: #fff; }
  .keynote-card p {
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: 13px;
    line-height: 1.5;
    color: #000;
  }
  .keynote-card.pink-card p { color: #fff; }

  /* SCHEDULE */
  .schedule-section {
    background: #fff;
    padding: 70px 80px;
    text-align: center;
  }
  .schedule-section h2 {
    font-family: 'Montserrat', sans-serif;
    font-weight: 900;
    font-size: 32px;
    color: var(--navy);
    margin-bottom: 50px;
  }
  .schedule-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .schedule-item {
    border-radius: 6px;
    overflow: hidden;
  }
  .schedule-time {
    padding: 14px 10px;
    font-family: 'Montserrat', sans-serif;
    font-weight: 900;
    font-size: 18px;
    color: #fff;
  }
  .schedule-time.cyan-bg { background: var(--cyan); }
  .schedule-time.pink-bg { background: var(--pink); }
  .schedule-label {
    background: #fff;
    border: 1px solid #e0e0e0;
    border-top: none;
    padding: 12px 10px;
    font-family: 'Montserrat', sans-serif;
    font-weight: 600;
    font-size: 12px;
    color: var(--text-dark);
    line-height: 1.4;
  }

  /* FOOTER */
  footer {
    background: var(--navy);
    color: rgba(255,255,255,0.6);
    text-align: center;
    padding: 30px;
    font-size: 13px;
  }

  /* LOCATION */
  .location-section {
    background: var(--light-gray);
    padding: 70px 80px;
  }
  .location-section h2 {
    font-family: 'Montserrat', sans-serif;
    font-weight: 900;
    font-size: 32px;
    color: var(--navy);
    margin-bottom: 40px;
    text-align: center;
  }
  .location-inner {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 40px;
    align-items: start;
  }
  .location-info {
    background: #fff;
    border-radius: 10px;
    padding: 30px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.07);
  }
  .location-icon {
    font-size: 32px;
    margin-bottom: 14px;
  }
  .location-info h3 {
    font-family: 'Montserrat', sans-serif;
    font-weight: 800;
    font-size: 18px;
    color: var(--navy);
    margin-bottom: 6px;
  }
  .location-info p {
    font-size: 14px;
    color: var(--text-mid);
    line-height: 1.6;
    margin-bottom: 4px;
  }
  .location-date {
    margin: 14px 0 20px !important;
    font-weight: 600;
    color: var(--navy) !important;
  }
  .btn-directions {
    display: inline-block;
    background: var(--navy);
    color: #fff;
    padding: 11px 20px;
    border-radius: 5px;
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: 13px;
    text-decoration: none;
    transition: background 0.2s;
  }
  .btn-directions:hover { background: var(--pink); }
  .map-container {
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  }

  /* CONTACT */
  .contact-section {
    background: var(--navy);
    padding: 70px 80px;
    color: #fff;
  }
  .contact-inner {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
  }
  .contact-section h2 {
    font-family: 'Montserrat', sans-serif;
    font-weight: 900;
    font-size: 32px;
    color: #fff;
    margin-bottom: 12px;
  }
  .contact-sub {
    font-size: 15px;
    color: rgba(255,255,255,0.7);
    margin-bottom: 40px;
  }
  .contact-details {
    display: flex;
    justify-content: center;
    gap: 50px;
    margin-bottom: 40px;
    flex-wrap: wrap;
  }
  .contact-item {
    display: flex;
    align-items: center;
    gap: 14px;
    text-align: left;
  }
  .contact-icon {
    font-size: 28px;
  }
  .contact-label {
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    margin-bottom: 4px;
  }
  .contact-link {
    color: #fff;
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
    transition: color 0.2s;
  }
  .contact-link:hover { color: var(--cyan); }
  .contact-socials {
    display: flex;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
  }
  .social-btn {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 12px 22px;
    border-radius: 6px;
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: 14px;
    text-decoration: none;
    color: #fff;
    transition: transform 0.15s, opacity 0.15s;
  }
  .social-btn:hover { transform: translateY(-2px); opacity: 0.9; }
  .social-btn.facebook { background: #1877f2; }
  .social-btn.instagram { background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888); }
  .social-btn.youtube { background: #ff0000; }

  @media (max-width: 900px) {
    .hero { grid-template-columns: 1fr; }
    .hero-right { height: 300px; }
    .info-section { grid-template-columns: 1fr; padding: 40px 30px; gap: 30px; }
    .countdown-section { padding: 30px; }
    .countdown-num, .countdown-sep { font-size: 44px; }
    .expect-section, .speaker-section, .schedule-section, .keynote-section { padding: 50px 30px; }
    .expect-grid, .schedule-grid, .keynote-grid { grid-template-columns: 1fr; }
    .location-inner { grid-template-columns: 1fr; }
    .location-section, .contact-section { padding: 50px 30px; }
    .contact-details { gap: 24px; flex-direction: column; align-items: center; }
    .contact-item { text-align: center; flex-direction: column; gap: 6px; }
  }
</style>
</head>
